  "evaluation_scripts": {
    "precision_at_k": "def precision_at_k(retrieved, relevant, k=5): return len(set(retrieved[:k]) & set(relevant)) / k",
    "recall_at_k": "def recall_at_k(retrieved, relevant, k=10): return len(set(retrieved[:k]) & set(relevant)) / len(relevant) if relevant else 0",
    "mrr": "def mrr(retrieved, relevant): return 1/(next((i+1 for i,d in enumerate(retrieved) if d in relevant), float('inf')))"
  },
  "aggregate_targets": {
    "mean_precision_at_5": 0.75,
    "mean_recall_at_10": 0.80,
    "mean_mrr": 0.70,
    "queries_passing_threshold": "18/20 (90%)"
  }
